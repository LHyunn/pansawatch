# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Runtime artifacts (cron logs, HF model cache, raw HTML cache)
/logs/
/gpu/hf-cache/
/data/news/raw/html/

# Pipeline research outputs — JSON files generated by daily-court-pipeline & friends.
# Regenerable from pipeline; keeping them out of git keeps repo lean.
/data/cases-master/*.json
/data/eval/*.json
/data/news/raw/*.json
/data/news/bodies/*.json
/data/reports/*.json

# One-time research / analysis / eval scripts. Local-only; not part of operational pipeline.
# Includes: build-eval-set, apply-eval-labels-demo, count-news-by-date,
#           count-yonhap-by-date, run-ie-eval (and any future research tools).
/scripts/research/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python (scratch scripts in repo root)
__pycache__/
*.pyc
*.pyo

# IDE / editor
.idea/
.vscode/

# OS
Thumbs.db

# Claude Code (user-local settings)
.claude/settings.local.json
