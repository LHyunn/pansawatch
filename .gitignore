# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python (scratch scripts in repo root)
__pycache__/
*.pyc
*.pyo

# IDE / editor
.idea/
.vscode/

# OS
Thumbs.db

# Claude Code (user-local settings)
.claude/settings.local.json

# research / experiment workspace (owner-area, not tracked)
/research/

# --- local data / large artifacts (not tracked) ---
/data/scourt_pdfs/
/data/seen-articles.json
/*.csv
/*.xlsx
*.log
